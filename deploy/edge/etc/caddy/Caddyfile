# Legacy Cloudflare-centric edge patterns are intentionally out of scope.
# This configuration is designed for WG-only edge/origin topology.

vaultmesh.org {
	encode zstd gzip

	log {
		output file /var/log/caddy/access.log
		format filter {
			fields {
				request>uri query {
					delete t
					delete token
					delete auth_token
					delete paypal_txn_id
					delete ticket_id
					delete lead_id
				}
			}
			wrap json
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; upgrade-insecure-requests"
	}

	@static_assets {
		path /favicon.ico /og/* /proof-pack/assets/*
		path *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.webp *.ico *.woff *.woff2 *.ttf *.map
	}
	header @static_assets {
		Cache-Control "public, max-age=31536000, immutable"
	}

	@crawlable_html {
		path / /trust /trust/ /brief /brief/ /changelog /changelog/ /proof-pack/
	}
	header @crawlable_html {
		Cache-Control "public, max-age=0, must-revalidate"
	}

	@operational_noindex {
		path /support /support/* /verify /verify/* /proof-pack/lead* /proof-pack/intake* /proof-pack/payment* /proof-pack/status* /proof-pack/pay/* /proof-pack/upload/* /support/ticket* /support/update* /support/resolve* /support/close* /support/reopen* /verify/zk*
	}
	header @operational_noindex {
		X-Robots-Tag "noindex, nofollow, nosnippet, noarchive"
		Cache-Control "no-store"
	}

	@proofpack_noslash {
		path /proof-pack
	}
	redir @proofpack_noslash /proof-pack/ 308

	@origin_gateway {
		path /proof-pack/lead* /proof-pack/intake /proof-pack/payment /proof-pack/status /support/ticket /support/update /support/resolve /support/close /support/reopen /verify/zk /proof/cc/heads /proof/cc/heads/latest
	}
	handle @origin_gateway {
		reverse_proxy {$ORIGIN_GATEWAY_UPSTREAM:10.44.0.3:9115}
	}

	# >>> VAULTMESH_DOCS_V0_1 >>>
	handle_path /docs* {
		root * /srv/web/vaultmesh/docs
		file_server
	}
	# <<< VAULTMESH_DOCS_V0_1 <<<
	root * /srv/web/vaultmesh
	file_server
}

offsec.global {
	encode zstd gzip

	log {
		output file /var/log/caddy/access.log
		format filter {
			fields {
				request>uri query {
					delete t
					delete token
					delete auth_token
					delete paypal_txn_id
					delete ticket_id
					delete lead_id
				}
			}
			wrap json
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; upgrade-insecure-requests"
	}

	@static_assets {
		path /favicon.ico /og/*
		path *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.webp *.ico *.woff *.woff2 *.ttf *.map
	}
	header @static_assets {
		Cache-Control "public, max-age=31536000, immutable"
	}

	@crawlable_html {
		path / /methodology /methodology/ /engagement-model /engagement-model/
	}
	header @crawlable_html {
		Cache-Control "public, max-age=0, must-revalidate"
	}

	@blocked_boundary {
		path /proof-pack /proof-pack/* /support /support/* /verify /verify/* /proof-pack/lead* /proof-pack/intake* /proof-pack/payment* /proof-pack/status* /proof/cc/* /_hooks/*
	}
	respond @blocked_boundary 404

	root * /srv/web/offsec
	file_server
}

# >>> VAULTMESH_INFRA_MCP_GATEWAY_V1 >>>
mcp.vaultmesh.org {
	# Gateway serves /mcp and /mcp/health natively.
	# Use `handle` (not `handle_path`) so the /mcp prefix is preserved upstream.
	@infra_mcp_api {
		path /mcp /mcp/*
	}
	handle @infra_mcp_api {
		reverse_proxy http://10.44.0.1:9126
	}
}
# <<< VAULTMESH_INFRA_MCP_GATEWAY_V1 <<<

hooks.vaultmesh.org {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	@hooks_allowlist {
		path /_hooks/mailgun /_hooks/n8n/* /webhook/* /webhook-test/* /support/status
	}
	header @hooks_allowlist {
		X-Robots-Tag "noindex, nofollow, nosnippet, noarchive"
		Cache-Control "no-store"
	}
	handle @hooks_allowlist {
		reverse_proxy {$VM_HOOKS_UPSTREAM} {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote}
		}
	}

	handle {
		respond 404
	}
}


# Temporary NetBird ingress proof endpoint
# NetBird Caddyfile Snippet
# Generated by getting-started.sh
#
# Add this block to your existing Caddyfile and reload Caddy

netbird.vaultmesh.org {
	# Native gRPC (needs HTTP/2 cleartext to backend)
	@grpc header Content-Type application/grpc*
	reverse_proxy @grpc h2c://127.0.0.1:8081

	# Combined server paths (relay, signal, management, OAuth2)
	@backend path /relay* /ws-proxy/* /api/* /oauth2/*
	reverse_proxy @backend 127.0.0.1:8081

	# Dashboard (everything else)
	reverse_proxy /* 127.0.0.1:8080
}

# >>> VAULTMESH_CC_WITNESS_HOST_V1_1 >>>
cc.vaultmesh.org {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}

	redir / /attest/ 308
	redir /attest /attest/ 308

	@attest_latest {
		path /attest/LATEST.txt
	}
	@attest_assets {
		path /attest/*
		not path /attest/LATEST.txt
	}
	header @attest_latest {
		Cache-Control "public, max-age=0, must-revalidate"
	}
	header @attest_assets {
		Cache-Control "public, max-age=31536000, immutable"
	}

	handle_path /attest/* {
		root * /srv/web/vaultmesh/attest
		file_server
		header {
			Vary "Accept-Encoding"
		}
	}

	@cc_console {
		path /cc /cc/*
	}
	handle @cc_console {
		reverse_proxy {$CC_GATEWAY_UPSTREAM:10.44.0.3:9115}
	}

	respond "Not found" 404
}
# <<< VAULTMESH_CC_WITNESS_HOST_V1_1 <<<
